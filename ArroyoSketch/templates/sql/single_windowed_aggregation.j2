INSERT INTO
    {{ sink_table }}
SELECT
    gzip_compress({{ agg_function }}({% if agg_columns %}concat_ws(';', {{ agg_columns }}), {% endif %}value{% if include_timestamps_as_argument %}{% if source_type == "kafka" %}, cast(extract(epoch from timestamp) * 1000 as bigint){% else %}, cast(timestamp as bigint){% endif %}{% endif %})) as precompute,
    {{ aggregation_id }} as aggregation_id,
    {% if group_by_columns %}concat_ws(';', {{ group_by_columns }}){% else %}''{% endif %} as key,
    TUMBLE(INTERVAL '{{ window_interval }}') as window
FROM
    {{ source_table }}
GROUP BY
    window, key
;
